# Simple Invoices – Docker environment
# Copy to .env and adjust as needed. Do not commit real credentials.
#
# ── Database adapter ──────────────────────────────────────────────────────────
# Three adapters are supported. Uncomment the block you want and comment out the
# others.  Then choose the matching docker-compose command:
#
#   MySQL/MariaDB (default):
#     docker compose up
#
#   SQLite (no db service required):
#     docker compose -f docker-compose.yml -f docker-compose.sqlite.yml up
#
#   PostgreSQL:
#     docker compose -f docker-compose.yml -f docker-compose.pgsql.yml up
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL / MariaDB ───────────────────────────────────────────────────────────
SI_DATABASE_ADAPTER=pdo_mysql
SI_DB_HOST=db
SI_DB_PORT=3306
SI_DB_USER=root
SI_DB_PASSWORD=rootpassword
SI_DB_NAME=simple_invoices

# --- Database (MariaDB service) ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=simple_invoices
MYSQL_USER=simpleuser
MYSQL_PASSWORD=simplepass

# --- Adminer ---
ADMINER_DEFAULT_SERVER=db
ADMINER_DEFAULT_USERNAME=root
ADMINER_DEFAULT_PASSWORD=rootpassword
# ─────────────────────────────────────────────────────────────────────────────

# ── SQLite ────────────────────────────────────────────────────────────────────
# Use with: docker compose -f docker-compose.yml -f docker-compose.sqlite.yml up
# Uncomment and comment out the MySQL block above to switch.
#SI_DATABASE_ADAPTER=pdo_sqlite
#SI_DB_HOST=
#SI_DB_PORT=
#SI_DB_USER=
#SI_DB_PASSWORD=
#SI_DB_NAME=simple_invoices
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Use with: docker compose -f docker-compose.yml -f docker-compose.pgsql.yml up
# Uncomment and comment out the MySQL block above to switch.
#SI_DATABASE_ADAPTER=pdo_pgsql
#SI_DB_HOST=db
#SI_DB_PORT=5432
#SI_DB_USER=siuser
#SI_DB_PASSWORD=sipassword
#SI_DB_NAME=simple_invoices
#POSTGRES_PASSWORD=sipassword
#POSTGRES_DB=simple_invoices
#POSTGRES_USER=siuser
# ─────────────────────────────────────────────────────────────────────────────

# --- App ---
SI_APP_NAME=Simple Invoices
SI_APP_LOGO=
APP_ENV=local
APP_DEBUG=true

# --- Ports (host:container) ---
SI_APP_PORT=8888
DB_PORT=3307
ADMINER_PORT=8081
SI_DATABASE_UTF8=true
SI_AUTHENTICATION_ENABLED=true
# Set true to show Register on the login page (new organisation + domain admin). Default false for safety.
SI_AUTHENTICATION_ALLOW_PUBLIC_DOMAIN_REGISTRATION=false
SI_AUTHENTICATION_HTTP=
SI_EXPORT_SPREADSHEET=xls
SI_EXPORT_WORDPROCESSOR=doc
SI_EXPORT_PDF_SCREENSIZE=800
SI_EXPORT_PDF_PAPERSIZE=A4
SI_EXPORT_PDF_LEFTMARGIN=15
SI_EXPORT_PDF_RIGHTMARGIN=15
SI_EXPORT_PDF_TOPMARGIN=15
SI_EXPORT_PDF_BOTTOMMARGIN=15
SI_LOCAL_LOCALE=en_GB
SI_LOCAL_PRECISION=2
SI_EMAIL_HOST=localhost
SI_EMAIL_SMTP_AUTH=false
SI_EMAIL_USERNAME=
SI_EMAIL_PASSWORD=
SI_EMAIL_SMTPPORT=25
SI_EMAIL_SECURE=
SI_EMAIL_ACK=false
SI_EMAIL_USE_LOCAL_SENDMAIL=false
SI_ENCRYPTION_DEFAULT_KEY=this_is_the_encryption_key_change_it
SI_NONCE_KEY=this_should_be_random_and_secret_so_change_it
SI_NONCE_TIMELIMIT=3600
SI_DEBUG_LEVEL=All
SI_DEBUG_ERROR_REPORTING=E_ERROR
SI_PHP_DATE_TIMEZONE=Europe/London
SI_PHP_DISPLAY_STARTUP_ERRORS=1
SI_PHP_DISPLAY_ERRORS=1
SI_PHP_LOG_ERRORS=0
SI_PHP_ERROR_LOG=tmp/log/php.log
SI_CONFIRM_DELETE_LINE_ITEM=no
SI_DB_WAIT_MAX=30
# Set to false to skip automatic SQL patch migration on container startup.
# Useful if you want to run patches manually via: php cli/run_patches.php
SI_AUTO_MIGRATE=true
SI_APP_WEBSITE=http://www.simpleinvoices.org
SI_APP_WEBSITE_LABEL=Website
SI_APP_FOOTER_LINK1_LABEL=Simple Invoices
SI_APP_FOOTER_LINK1_URL=http://www.simpleinvoices.org
SI_APP_FOOTER_LINK2_LABEL=Forum
SI_APP_FOOTER_LINK2_URL=http://www.simpleinvoices.org/+
SI_APP_FOOTER_LINK3_LABEL=Blog
SI_APP_FOOTER_LINK3_URL=http://www.simpleinvoices.org/blog
SI_APP_FOOTER_LINK4_LABEL=Support
SI_APP_FOOTER_LINK4_URL=http://www.simpleinvoices.org/forum
SI_APP_FOOTER_TEXT=Thank you for using
