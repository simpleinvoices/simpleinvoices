# Simple Invoices – Docker environment
# Copy to .env and adjust as needed. Do not commit real credentials.

# --- App (simpleinvoices) ---
SI_DB_HOST=db
SI_DB_PORT=3306
SI_DB_USER=root
SI_DB_PASSWORD=rootpassword
SI_DB_NAME=simple_invoices
# Header branding (optional; can also set in config/custom.config.php as app.name and app.logo)
SI_APP_NAME=Simple Invoices
SI_APP_LOGO=

# --- Database (MariaDB) ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=simple_invoices
MYSQL_USER=simpleuser
MYSQL_PASSWORD=simplepass

# --- Adminer ---
ADMINER_DEFAULT_SERVER=db
ADMINER_DEFAULT_USERNAME=root
ADMINER_DEFAULT_PASSWORD=rootpassword

# --- Ports (host:container) ---
SI_APP_PORT=8888
DB_PORT=3307
ADMINER_PORT=8081

# --- App extras (config/config.php overrides for Docker) ---
SI_DATABASE_ADAPTER=pdo_mysql
SI_DATABASE_UTF8=true
SI_AUTHENTICATION_ENABLED=false
SI_AUTHENTICATION_HTTP=
SI_EXPORT_SPREADSHEET=xls
SI_EXPORT_WORDPROCESSOR=doc
SI_EXPORT_PDF_SCREENSIZE=800
SI_EXPORT_PDF_PAPERSIZE=A4
SI_EXPORT_PDF_LEFTMARGIN=15
SI_EXPORT_PDF_RIGHTMARGIN=15
SI_EXPORT_PDF_TOPMARGIN=15
SI_EXPORT_PDF_BOTTOMMARGIN=15
SI_LOCAL_LOCALE=en_GB
SI_LOCAL_PRECISION=2
SI_EMAIL_HOST=localhost
SI_EMAIL_SMTP_AUTH=false
SI_EMAIL_USERNAME=
SI_EMAIL_PASSWORD=
SI_EMAIL_SMTPPORT=25
SI_EMAIL_SECURE=
SI_EMAIL_ACK=false
SI_EMAIL_USE_LOCAL_SENDMAIL=false
SI_ENCRYPTION_DEFAULT_KEY=this_is_the_encryption_key_change_it
SI_NONCE_KEY=this_should_be_random_and_secret_so_change_it
SI_NONCE_TIMELIMIT=3600
SI_DEBUG_LEVEL=All
SI_DEBUG_ERROR_REPORTING=E_ERROR
SI_PHP_DATE_TIMEZONE=Europe/London
SI_PHP_DISPLAY_STARTUP_ERRORS=1
SI_PHP_DISPLAY_ERRORS=1
SI_PHP_LOG_ERRORS=0
SI_PHP_ERROR_LOG=tmp/log/php.log
SI_CONFIRM_DELETE_LINE_ITEM=no
SI_DB_WAIT_MAX=30
